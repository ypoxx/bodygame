{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AnatomyQuest Structures",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["id", "nameDe", "nameLatin", "funFact", "layer", "tags"],
    "properties": {
      "id": { "type": "string", "minLength": 1 },
      "nameDe": { "type": "string", "minLength": 1 },
      "nameLatin": { "type": "string", "minLength": 1 },
      "funFact": { "type": "string", "minLength": 1 },
      "layer": { "type": "string", "enum": ["bones", "muscles", "fasciae"] },
      "tags": {
        "type": "array",
        "items": { "type": "string" },
        "minItems": 1
      }
    },
    "additionalProperties": false
  }
}
