{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://anatomyquest.app/schemas/v2/phase-b-package-manifest.schema.json",
  "title": "AnatomyQuest Phase B working package manifest",
  "type": "object",
  "required": [
    "$schema",
    "schemaVersion",
    "manifestVersion",
    "packageId",
    "phase",
    "assetDomain",
    "packageSequence",
    "titleDe",
    "assignmentBasis",
    "assignmentStatus",
    "reviewPriority",
    "expectedConceptCount",
    "expectedInstanceCount",
    "conceptIds",
    "stopTheLineConceptIds"
  ],
  "properties": {
    "$schema": {
      "const": "../../../../schemas/v2/phase-b-package-manifest.schema.json"
    },
    "schemaVersion": {
      "const": 1
    },
    "manifestVersion": {
      "const": "1.0.0"
    },
    "packageId": {
      "type": "string",
      "pattern": "^phase_b\\.(skeleton|muscles|connective_tissue)\\.[a-z0-9_]+$"
    },
    "phase": {
      "const": "phase_b"
    },
    "assetDomain": {
      "enum": [
        "skeleton",
        "muscles",
        "connective_tissue"
      ]
    },
    "packageSequence": {
      "type": "integer",
      "minimum": 1,
      "maximum": 8
    },
    "titleDe": {
      "type": "string",
      "minLength": 1
    },
    "assignmentBasis": {
      "const": "working_asset_label"
    },
    "assignmentStatus": {
      "const": "working_assignment_not_medically_verified"
    },
    "reviewPriority": {
      "enum": [
        "standard",
        "stop_the_line_first"
      ]
    },
    "expectedConceptCount": {
      "type": "integer",
      "minimum": 1,
      "maximum": 496
    },
    "expectedInstanceCount": {
      "type": "integer",
      "minimum": 1,
      "maximum": 946
    },
    "conceptIds": {
      "type": "array",
      "minItems": 1,
      "maxItems": 496,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^concept\\.(skeleton|soft_tissue)\\.[a-z0-9_]+$"
      }
    },
    "stopTheLineConceptIds": {
      "type": "array",
      "maxItems": 4,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^concept\\.soft_tissue\\.[a-z0-9_]+$"
      }
    }
  },
  "additionalProperties": false
}
